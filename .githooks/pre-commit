#!/bin/sh
# Secret-scan pre-commit hook — blocks commits that contain credentials.
# No external dependency: scans the STAGED diff for common secret patterns.
# Enable once with:  git config core.hooksPath .githooks
set -eu

# Only look at lines being ADDED (leading '+'), across staged changes.
added="$(git diff --cached --unified=0 --no-color | grep -E '^\+' | grep -vE '^\+\+\+' || true)"
[ -z "$added" ] && exit 0

fail=0
report() { printf '\033[31m✖ Possible secret blocked:\033[0m %s\n' "$1" >&2; fail=1; }

# AWS access key id
echo "$added" | grep -Eq '(AKIA|ASIA)[0-9A-Z]{16}' && report "AWS Access Key ID"
# AWS secret access key (40-char base64 next to an aws hint)
echo "$added" | grep -Eiq 'aws_?secret_?access_?key.{0,20}[A-Za-z0-9/+=]{40}' && report "AWS Secret Access Key"
# Private keys
echo "$added" | grep -Eq 'BEGIN (RSA |EC |OPENSSH |DSA |PGP )?PRIVATE KEY' && report "Private key block"
# Generic high-entropy assignments to obvious secret names
echo "$added" | grep -Eiq '(secret|password|passwd|token|api[_-]?key)[\"'"'"' ]*[:=][\"'"'"' ]*[A-Za-z0-9/+_-]{20,}' && report "Hardcoded secret/token assignment"
# Inline AWS creds on a command line (the habit that burned the account)
echo "$added" | grep -Eq 'AWS_(ACCESS_KEY_ID|SECRET_ACCESS_KEY)=' && report "Inline AWS credential on command line"

if [ "$fail" -ne 0 ]; then
  cat >&2 <<'MSG'

Commit aborted: a credential pattern was detected in your staged changes.
 - Remove the secret, use a gitignored .env or AWS SSO/named profiles.
 - If this is a false positive, bypass once with:  git commit --no-verify
MSG
  exit 1
fi
exit 0
